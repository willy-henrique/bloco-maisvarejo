rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrador';
    }
    function isGerente() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['administrador', 'gerente'];
    }
    function isDeveloper() {
      return isAuthenticated() &&
        ('email' in request.auth.token) &&
        request.auth.token.email == 'willydev01@gmail.com';
    }

    match /board/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /appSettings/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
    }

    match /dev_usage/{userId} {
      allow read: if isDeveloper();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /strategic_items/{itemId} {
      allow read, write: if isAuthenticated();
    }

    match /chat/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.texto is string
        && request.resource.data.texto.size() > 0
        && request.resource.data.texto.size() <= 2000;
      allow update, delete: if false;
    }

    match /privateChats/{chatId} {
      function isParticipant() {
        return isAuthenticated() &&
          request.auth.uid in resource.data.participants;
      }
      function isParticipantOnCreate() {
        return isAuthenticated() &&
          request.auth.uid in request.resource.data.participants;
      }

      allow read: if isParticipant();
      allow create: if isParticipantOnCreate()
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants is list;
      allow update: if isParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        function isMessageParticipant() {
          return isAuthenticated()
            && request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants;
        }
        function messageWasNotDeletedForEveryone() {
          return !('deletedForEveryone' in resource.data) || resource.data.deletedForEveryone == false;
        }
        function canUseDeleteForEveryoneWindow() {
          return (
            resource.data.createdAtServer is timestamp
            && request.time.toMillis() <= resource.data.createdAtServer.toMillis() + 180000
          ) || (
            !('createdAtServer' in resource.data)
            && resource.data.createdAt is number
            && request.time.toMillis() <= resource.data.createdAt + 180000
          );
        }
        function editsOwnMessageText() {
          return resource.data.senderUid == request.auth.uid
            && isMessageParticipant()
            && messageWasNotDeletedForEveryone()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['texto', 'editedAt'])
            && request.resource.data.texto is string
            && request.resource.data.texto.size() > 0
            && request.resource.data.texto.size() <= 4000
            && request.resource.data.editedAt is number;
        }
        function deletesMessageForSelf() {
          return isMessageParticipant()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor'])
            && request.resource.data.deletedFor is map
            && request.resource.data.deletedFor[request.auth.uid] == true
            && (
              (
                !('deletedFor' in resource.data)
                && request.resource.data.deletedFor.keys().hasOnly([request.auth.uid])
              ) || (
                resource.data.deletedFor is map
                && request.resource.data.deletedFor.diff(resource.data.deletedFor).affectedKeys().hasOnly([request.auth.uid])
              )
            );
        }
        function deletesOwnMessageForEveryone() {
          return resource.data.senderUid == request.auth.uid
            && isMessageParticipant()
            && messageWasNotDeletedForEveryone()
            && canUseDeleteForEveryoneWindow()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['texto', 'deletedForEveryone', 'deletedAt'])
            && request.resource.data.texto == ''
            && request.resource.data.deletedForEveryone == true
            && request.resource.data.deletedAt is number;
        }
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants;
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.keys().hasOnly(['senderUid', 'senderNome', 'texto', 'createdAt', 'createdAtServer'])
          && request.resource.data.senderNome is string
          && request.resource.data.createdAt is number
          && request.resource.data.createdAtServer == request.time
          && request.resource.data.texto is string
          && request.resource.data.texto.size() > 0
          && request.resource.data.texto.size() <= 4000;
        allow update: if editsOwnMessageText()
          || deletesMessageForSelf()
          || deletesOwnMessageForEveryone();
        allow delete: if false;
      }
    }

    match /director_notes/{noteId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // collectionGroup read for viewers querying their own incoming eventInvites
    match /{path=**}/eventInvites/{inviteId} {
      allow read: if isAuthenticated() && resource.data.viewerUid == request.auth.uid;
    }

    // collectionGroup read for viewers querying their own incoming agendaInvites
    match /{path=**}/agendaInvites/{viewerId} {
      allow read: if isAuthenticated() && resource.data.viewerUid == request.auth.uid;
    }

    match /userAgenda/{userId} {
      function hasAcceptedAgendaInvite() {
        return exists(/databases/$(database)/documents/userAgenda/$(userId)/agendaInvites/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/userAgenda/$(userId)/agendaInvites/$(request.auth.uid)).data.status == 'accepted';
      }

      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || hasAcceptedAgendaInvite());
      allow create, update, delete: if isAuthenticated() && request.auth.uid == userId;

      match /agendaInvites/{viewerId} {
        function inviteShapeIsValid() {
          return request.resource.data.ownerUid == userId &&
            request.resource.data.viewerUid == viewerId &&
            request.resource.data.status in ['pending', 'accepted', 'declined'];
        }

        function viewerResponseIsValid() {
          return resource.data.ownerUid == userId &&
            resource.data.viewerUid == viewerId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'rejectionReason',
              'respondedAt',
              'updatedAt'
            ]) &&
            request.resource.data.status in ['accepted', 'declined'] &&
            (
              request.resource.data.status == 'accepted' ||
              (
                request.resource.data.rejectionReason is string &&
                request.resource.data.rejectionReason.size() > 0 &&
                request.resource.data.rejectionReason.size() <= 1000
              )
            );
        }

        allow read: if isAuthenticated() &&
          (
            request.auth.uid == userId ||
            resource.data.viewerUid == request.auth.uid
          );
        allow create: if isAuthenticated() &&
          request.auth.uid == userId &&
          inviteShapeIsValid() &&
          request.resource.data.status == 'pending';
        allow update: if isAuthenticated() &&
          (
            (
              request.auth.uid == userId &&
              inviteShapeIsValid() &&
              request.resource.data.status == 'pending'
            ) ||
            (
              request.auth.uid == viewerId &&
              viewerResponseIsValid()
            )
          );
        allow delete: if isAuthenticated() &&
          (request.auth.uid == userId || request.auth.uid == viewerId);
      }

      match /eventInvites/{inviteId} {
        function eventInviteShapeIsValid() {
          return request.resource.data.ownerUid == userId &&
            request.resource.data.viewerUid is string &&
            request.resource.data.eventId is string &&
            request.resource.data.status in ['pending', 'accepted', 'declined'];
        }

        function eventViewerResponseIsValid() {
          return resource.data.ownerUid == userId &&
            resource.data.viewerUid == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'rejectionReason',
              'respondedAt',
              'updatedAt'
            ]) &&
            request.resource.data.status in ['accepted', 'declined'] &&
            (
              request.resource.data.status == 'accepted' ||
              (
                request.resource.data.rejectionReason is string &&
                request.resource.data.rejectionReason.size() > 0 &&
                request.resource.data.rejectionReason.size() <= 1000
              )
            );
        }

        allow read: if isAuthenticated() &&
          (
            request.auth.uid == userId ||
            resource.data.viewerUid == request.auth.uid
          );
        allow create: if isAuthenticated() &&
          request.auth.uid == userId &&
          eventInviteShapeIsValid() &&
          request.resource.data.status == 'pending';
        allow update: if isAuthenticated() &&
          (
            (
              request.auth.uid == userId &&
              eventInviteShapeIsValid() &&
              request.resource.data.viewerUid == resource.data.viewerUid &&
              request.resource.data.eventId == resource.data.eventId &&
              request.resource.data.status == resource.data.status
            ) ||
            eventViewerResponseIsValid()
          );
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
